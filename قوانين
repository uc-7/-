<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Respect Network | قوانين السيرفر</title>
    <link href="https://fonts.googleapis.com/css2? Cairo:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);
            color: #fff;
            min-height: 100vh;
            line-height: 1.6;
        }

        /* خلفية متحركة بنجوم */
        .stars {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            background: radial-gradient(2px 2px at 20px 30px, #eee, rgba(0,0,0,0)),
                        radial-gradient(1px 1px at 40px 70px, #fff, rgba(0,0,0,0));
            background-size: 200px 200px, 150px 150px;
            background-repeat: repeat;
            opacity: 0.3;
            z-index: 0;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
            position: relative;
            z-index: 1;
        }

        /* الهيدر */
        .header {
            text-align: center;
            padding: 40px 20px;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(10px);
            border-radius: 30px;
            margin-bottom: 40px;
            border: 1px solid rgba(255, 215, 0, 0.3);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        }

        .logo {
            font-size: 70px;
            margin-bottom: 15px;
        }

        .server-name {
            font-size: 48px;
            font-weight: 800;
            background: linear-gradient(135deg, #ffd700, #ffaa00);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: 2px;
        }

        .tagline {
            color: #aaa;
            font-size: 18px;
            margin-top: 10px;
        }

        /* بطاقة السيرفر */
        .server-card {
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 25px;
            margin-bottom: 40px;
            border: 1px solid rgba(255, 215, 0, 0.2);
            text-align: center;
        }

        .ip-box {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .ip-address {
            background: rgba(0, 0, 0, 0.7);
            padding: 12px 25px;
            border-radius: 50px;
            font-size: 24px;
            font-weight: 600;
            letter-spacing: 1px;
            font-family: monospace;
            border: 1px solid #ffd700;
            color: #ffd700;
        }

        .copy-btn {
            background: linear-gradient(135deg, #ffd700, #ffaa00);
            border: none;
            padding: 12px 25px;
            border-radius: 50px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            font-family: 'Cairo', sans-serif;
        }

        .copy-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 20px rgba(255, 215, 0, 0.4);
        }

        .server-status {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: rgba(0, 0, 0, 0.5);
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 14px;
        }

        .status-online {
            width: 12px;
            height: 12px;
            background: #00ff00;
            border-radius: 50%;
            animation: pulse 1.5s infinite;
        }

        .status-offline {
            width: 12px;
            height: 12px;
            background: #ff0000;
            border-radius: 50%;
        }

        @keyframes pulse {
            0% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(1.2); }
            100% { opacity: 1; transform: scale(1); }
        }

        /* القوانين */
        .rules-section {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 25px;
            margin-bottom: 40px;
        }

        .rule-card {
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 25px;
            border: 1px solid rgba(255, 215, 0, 0.15);
            transition: transform 0.3s, border-color 0.3s;
        }

        .rule-card:hover {
            transform: translateY(-5px);
            border-color: rgba(255, 215, 0, 0.4);
        }

        .rule-icon {
            font-size: 40px;
            margin-bottom: 15px;
        }

        .rule-title {
            font-size: 24px;
            font-weight: 700;
            color: #ffd700;
            margin-bottom: 20px;
            border-right: 4px solid #ffd700;
            padding-right: 15px;
        }

        .rule-list {
            list-style: none;
        }

        .rule-list li {
            margin-bottom: 12px;
            padding-right: 25px;
            position: relative;
            color: #ddd;
        }

        .rule-list li:before {
            content: "⚠️";
            position: absolute;
            right: 0;
            font-size: 14px;
        }

        /* الفوتر */
        .footer {
            text-align: center;
            padding: 30px;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            border: 1px solid rgba(255, 215, 0, 0.15);
        }

        .social-links {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 20px;
        }

        .social-links a {
            color: #fff;
            font-size: 28px;
            transition: color 0.3s, transform 0.3s;
        }

        .social-links a:hover {
            color: #ffd700;
            transform: translateY(-3px);
        }

        .copyright {
            color: #666;
            font-size: 14px;
        }

        /* رسالة الإشعار */
        .toast {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: #ffd700;
            color: #1a1a2e;
            padding: 12px 24px;
            border-radius: 50px;
            font-weight: bold;
            transform: translateX(400px);
            transition: transform 0.3s;
            z-index: 1000;
        }

        .toast.show {
            transform: translateX(0);
        }

        @media (max-width: 768px) {
            .server-name { font-size: 32px; }
            .ip-address { font-size: 18px; }
            .rules-section { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="stars"></div>

    <div class="container">
        <!-- الهيدر -->
        <div class="header">
            <div class="logo">👑</div>
            <h1 class="server-name">RESPECT NETWORK</h1>
            <p class="tagline">حيث الاحترام أساس المتعة | Where Respect is the Key to Fun</p>
        </div>

        <!-- بطاقة السيرفر -->
        <div class="server-card">
            <div class="ip-box">
                <span class="ip-address" id="server-ip">play.respect-network.com</span>
                <button class="copy-btn" onclick="copyIP()">
                    <i class="fas fa-copy"></i> نسخ الآي بي
                </button>
            </div>
            <div class="server-status">
                <div class="status-online" id="status-indicator"></div>
                <span id="status-text">جاري التحقق...</span>
                <span id="player-count"></span>
            </div>
        </div>

        <!-- القوانين -->
        <div class="rules-section">
            <!-- القسم 1: القوانين العامة -->
            <div class="rule-card">
                <div class="rule-icon">📜</div>
                <h2 class="rule-title">القوانين العامة</h2>
                <ul class="rule-list">
                    <li>احترام الجميع - لا للتكسير أو السب أو العنصرية</li>
                    <li>الغش والخدع ممنوع منعاً باتاً (Hacks, Cheats, Exploits)</li>
                    <li>لا للتخريب - يمنع تحطيم مباني الآخرين</li>
                    <li>لا للسرقة - صناديق ومنازل الآخرين خاصة</li>
                    <li>الالتزام بالتعليمات الصادرة من فريق الإدارة</li>
                </ul>
            </div>

            <!-- القسم 2: الشات والتواصل -->
            <div class="rule-card">
                <div class="rule-icon">💬</div>
                <h2 class="rule-title">الشات والتواصل</h2>
                <ul class="rule-list">
                    <li>السب والشتم والتنمر ممنوع</li>
                    <li>الإعلانات عن سيرفرات أخرى محظورة</li>
                    <li>إرسال رسائل مزعجة (Spam) غير مسموح</li>
                    <li>المحتوى غير اللائق أو الإباحي ممنوع</li>
                    <li>احترام آراء الآخرين والنقاش الهادف</li>
                </ul>
            </div>

            <!-- القسم 3: اللعب والعمارة -->
            <div class="rule-card">
                <div class="rule-icon">🏗️</div>
                <h2 class="rule-title">البناء واللعب</h2>
                <ul class="rule-list">
                    <li>لا للبناء قريب جداً من الآخرين دون إذن</li>
                    <li>المصائد القاتلة غير العادلة ممنوعة</li>
                    <li>PVP فقط بالتراضي بين الطرفين</li>
                    <li>المزارع والآليات التي تسبب لاق للخادم ممنوعة</li>
                    <li>الاستغلال الثغرات (Exploits) يعرضك للطرد</li>
                </ul>
            </div>

            <!-- القسم 4: الاقتصاد والتجارة -->
            <div class="rule-card">
                <div class="rule-icon">💰</div>
                <h2 class="rule-title">الاقتصاد والتجارة</h2>
                <ul class="rule-list">
                    <li>النصب والاحتيال في الصفقات ممنوع</li>
                    <li>تكرار الأغراض (Duplication) حرام</li>
                    <li>بيع الأغراض مقابل أموال حقيقية ممنوع</li>
                    <li>استغلال أخطاء الاقتصاد يعتبر مخالفة</li>
                    <li>الشفافية في جميع المعاملات التجارية</li>
                </ul>
            </div>

            <!-- القسم 5: العقوبات -->
            <div class="rule-card">
                <div class="rule-icon">⚖️</div>
                <h2 class="rule-title">نظام العقوبات</h2>
                <ul class="rule-list">
                    <li>المخالفة الأولى: إنذار كتابي</li>
                    <li>المخالفة الثانية: حظر مؤقت (3 أيام - أسبوع)</li>
                    <li>المخالفة الثالثة: حظر دائم (Permanent Ban)</li>
                    <li>الغش والخدع: حظر دائم فوري</li>
                    <li>الطعن في العقوبات عبر تذكرت في الديسكورد</li>
                </ul>
            </div>

            <!-- القسم 6: الشروط الإضافية -->
            <div class="rule-card">
                <div class="rule-icon">📌</div>
                <h2 class="rule-title">شروط إضافية</h2>
                <ul class="rule-list">
                    <li>ممنوع انتحال شخصية الإدارة أو Staff</li>
                    <li>استخدام الأسماء المسيئة أو الاستفزازية ممنوع</li>
                    <li>التزوير في طلبات المساعدة يعرضك للعقاب</li>
                    <li>الموافقة على القوانين شرط للعب</li>
                    <li>الإدارة تحتفظ بحق تعديل القوانين</li>
                </ul>
            </div>
        </div>

        <!-- الفوتر -->
        <div class="footer">
            <div class="social-links">
                <a href="#" target="_blank"><i class="fab fa-discord"></i></a>
                <a href="#" target="_blank"><i class="fab fa-twitter"></i></a>
                <a href="#" target="_blank"><i class="fab fa-instagram"></i></a>
                <a href="#" target="_blank"><i class="fab fa-tiktok"></i></a>
                <a href="#" target="_blank"><i class="fab fa-youtube"></i></a>
            </div>
            <div class="copyright">
                © 2026 Respect Network | كل الحقوق محفوظة | تم التطوير بواسطة فريق RESPECT
            </div>
        </div>
    </div>

    <div class="toast" id="toast">✅ تم نسخ الآي بي!</div>

    <script>
        // إعدادات السيرفر - عدل هنا حسب معلومات سيرفرك
        const SERVER_CONFIG = {
            ip: "play.respect-network.com",     // آي بي السيرفر
            port: 25565,                         // البورت (غالباً 25565 للجافا)
            apiUrl: "https://api.mcsrvstat.us/2/" // API جاهزة لفحص الحالة
        };

        // تحديث واجهة الآي بي
        document.getElementById("server-ip").textContent = SERVER_CONFIG.ip;

        // وظيفة نسخ الآي بي
        function copyIP() {
            const ip = document.getElementById("server-ip").textContent;
            navigator.clipboard.writeText(ip).then(() => {
                const toast = document.getElementById("toast");
                toast.classList.add("show");
                setTimeout(() => {
                    toast.classList.remove("show");
                }, 2000);
            });
        }

        // فحص حالة السيرفر
        async function checkServerStatus() {
            const statusIndicator = document.getElementById("status-indicator");
            const statusText = document.getElementById("status-text");
            const playerCountSpan = document.getElementById("player-count");

            try {
                const response = await fetch(`${SERVER_CONFIG.apiUrl}${SERVER_CONFIG.ip}`);
                const data = await response.json();

                if (data.online) {
                    statusIndicator.className = "status-online";
                    statusText.textContent = "🟢 السيرفر متصل";
                    if (data.players && data.players.online !== undefined) {
                        playerCountSpan.textContent = ` | 👥 ${data.players.online}/${data.players.max} لاعب`;
                    } else {
                        playerCountSpan.textContent = "";
                    }
                } else {
                    statusIndicator.className = "status-offline";
                    statusText.textContent = "🔴 السيرفر غير متصل";
                    playerCountSpan.textContent = "";
                }
            } catch (error) {
                console.error("خطأ في فحص حالة السيرفر:", error);
                statusIndicator.className = "status-offline";
                statusText.textContent = "🔴 تعذر الاتصال";
                playerCountSpan.textContent = "";
            }
        }

        // فحص الحالة عند تحميل الصفحة وكل 30 ثانية
        checkServerStatus();
        setInterval(checkServerStatus, 30000);

        // تأثيرات إضافية - تحريك الخلفية
        document.addEventListener("mousemove", function(e) {
            const stars = document.querySelector(".stars");
            const x = e.clientX / window.innerWidth;
            const y = e.clientY / window.innerHeight;
            stars.style.transform = `translate(${x * 10}px, ${y * 10}px)`;
        });
    </script>
</body>
</html>
